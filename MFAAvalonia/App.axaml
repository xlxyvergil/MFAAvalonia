<Application
    RequestedThemeVariant="Light"
    x:Class="MFAAvalonia.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:sukiUi="clr-namespace:SukiUI;assembly=SukiUI"
    xmlns:fluentIcons="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:styling="clr-namespace:FluentAvalonia.Styling;assembly=FluentAvalonia">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://MFAAvalonia.Core/Assets/Style/Geometry.axaml" />
                <ResourceInclude Source="avares://MFAAvalonia.Core/Assets/Style/MdXaml.axaml" />
                <ResourceInclude Source="avares://MFAAvalonia.Core/Views/UserControls/TooltipBlock.axaml" />
                <ResourceInclude Source="avares://MFAAvalonia.Core/Views/UserControls/DisplayIcon.axaml" />
                <ResourceInclude Source="avares://MFAAvalonia.Core/Views/UserControls/SchedulePicker.axaml" />
                <ResourceInclude Source="avares://MFAAvalonia.Core/Views/UserControls/MarqueeTextBlock.axaml" />
                <ResourceInclude Source="avares://MFAAvalonia.Core/Assets/Style/InstanceTabsTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceInclude Source="avares://MFAAvalonia.Core/Assets/Theme/LightTheme.axaml" x:Key="Light" />
                <ResourceInclude Source="avares://MFAAvalonia.Core/Assets/Theme/DarkTheme.axaml" x:Key="Dark" />
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>

    </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <styling:FluentAvaloniaTheme />
        <sukiUi:SukiTheme ThemeColor="Blue" />
        <StyleInclude Source="avares://MFAAvalonia.Core/Views/UserControls/HotKeyEditor.axaml" />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />

        <Style Selector="Thumb.DashboardGridSplitter">
            <Setter Property="Cursor" Value="SizeWestEast" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Background="Transparent" RowDefinitions="*,Auto,*">
                        <Border Width="1"
                                Background="{DynamicResource SukiControlBorderBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Margin="0,4" />
                        <StackPanel Grid.Row="1"
                                    Spacing="4" Margin="0 10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                        </StackPanel>
                        <Border Grid.Row="2"
                                Width="1"
                                Background="{DynamicResource SukiControlBorderBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Margin="0,4" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Thumb.DashboardGridSplitterHorizontal">
            <Setter Property="Cursor" Value="SizeNorthSouth" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Background="Transparent" ColumnDefinitions="*,Auto,*">
                        <Border Height="1"
                                Background="{DynamicResource SukiControlBorderBrush}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch"
                                Margin="4,0" />
                        <StackPanel Grid.Column="1"
                                    Spacing="4" Margin="10,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                        </StackPanel>
                        <Border Grid.Column="2"
                                Height="1"
                                Background="{DynamicResource SukiControlBorderBrush}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch"
                                Margin="4,0" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="MenuItem.DangerContextDelete">
            <Setter Property="Foreground" Value="{DynamicResource SukiDangerColor}" />
        </Style>
        <Style Selector="MenuItem.DangerContextDelete:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource SukiDangerColor}" />
        </Style>
        <Style Selector="MenuItem.DangerContextDelete:pressed">
            <Setter Property="Foreground" Value="{DynamicResource SukiDangerColor}" />
        </Style>
        <Style Selector="MenuItem.DangerContextDelete fluentIcons|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource SukiDangerColor}" />
        </Style>

        <Style Selector="NumericUpDown.TaskOptionLikeCombo">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="NumericUpDown.TaskOptionLikeCombo /template/ Control#PART_GlassCard">
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="NumericUpDown.TaskOptionLikeCombo /template/ ButtonSpinner#PART_Spinner">
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>

        <Style Selector="TimePicker.TaskOptionLikeCombo">
            <Setter Property="Height" Value="30" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
        <Style Selector="TimePicker.TaskOptionLikeCombo /template/ Button#PART_FlyoutButton">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MaxWidth" Value="4096" />
        </Style>

    </Application.Styles>
</Application>
